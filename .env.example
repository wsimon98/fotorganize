# fotorganize config — copy to .env and edit. All paths may be absolute or relative to project root.

# --- server ---
HOST=127.0.0.1
PORT=8420
# DANGER: setting ALLOW_LAN=true binds to 0.0.0.0 and exposes your private family
# photo library to every device on your network. Read docs/windows_setup.md first.
ALLOW_LAN=false

# --- storage ---
DB_PATH=data/app.db
THUMBNAIL_DIR=data/thumbnails
FACE_CROP_DIR=data/face_crops
EXPORT_DIR=data/exports
LOG_DIR=data/logs

# --- scanning ---
SCAN_BATCH_SIZE=200
THUMBNAIL_SIZE=512

# --- AI (Phase 3+; not used yet) ---
GPU_ENABLED=true
CAPTION_MODEL=microsoft/Florence-2-base
FACE_MODEL=buffalo_l
# HF_HOME=F:/fotorganize/data/models

# --- behavior ---
# show images from inactive sources in the UI by default
SHOW_INACTIVE_SOURCES=false
# Phase 10: write XMP sidecars next to originals (opt-in, off by default)
WRITE_XMP_SIDECARS=false
